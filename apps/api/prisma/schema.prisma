generator client {
  provider                    = "prisma-client-py"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum CandidateStatus {
  UNCLAIMED
  CLAIMED
  ACTIVE
  ARCHIVED
}

enum CompanyMemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum CompanyType {
  CHINESE
  WFOE
  RO
  FOREIGN_STARTUP
  AGENCY
  OTHER
}

enum OrgSize {
  SOLO
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum CompanyVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum CompanyVerificationDocType {
  BUSINESS_LICENSE
  TAX_CERTIFICATE
  LEGAL_REP_ID
  AUTHORIZATION_LETTER
  OTHER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum RemotePolicy {
  ONSITE
  HYBRID
  REMOTE
}

enum ContactVisibilityPolicy {
  PUBLIC
  APPLICANTS_ONLY
  PREMIUM_ONLY
}

enum JobSource {
  DIRECT
  SCRAPED
  PARTNER
}

enum JobLanguage {
  ENGLISH
  CHINESE
  BENGALI
  OTHER
}

enum LanguageLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  FLUENT
  NATIVE
}

enum ChineseRequiredLevel {
  NONE
  BASIC
  INTERMEDIATE
  HSK4
  HSK5
  FLUENT
}

enum EducationLevel {
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
  OTHER
}

enum EnglishProficiencyType {
  IELTS
  DUOLINGO
  SAT
  GED
  TOEFL
  OTHER
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum MediaVisibility {
  PRIVATE
  COMPANY_ONLY
  PUBLIC
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum TranslationStatus {
  DRAFT
  PUBLISHED
}

enum LocaleCode {
  EN @map("en")
  ZH @map("zh")
  BN @map("bn")
}

enum TaxonomyEntityType {
  INDUSTRY
  FUNCTION
  CATEGORY
}

enum EntitlementScope {
  USER
  COMPANY
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  candidate             Candidate?
  userRoles             UserRole[]
  companyMembers        CompanyMember[]
  ownedMediaAssets      MediaAsset[]           @relation("MediaOwner")
  trackingEvents        TrackingEvent[]
  trackingEventsArchive TrackingEventArchive[]
  authoredMessages      Message[]              @relation("MessageAuthor")
  applicationEvents     ApplicationEvent[]     @relation("ApplicationEventActor")
  applicationNotes      ApplicationNote[]      @relation("ApplicationNoteAuthor")
  authoredBlogPosts     BlogPost[]             @relation("BlogPostAuthor")
  authoredBlogPostTrans BlogPostTranslation[]  @relation("BlogPostTranslationAuthor")
  authoredTutorials     Tutorial[]             @relation("TutorialAuthor")
  authoredTutorialTrans TutorialTranslation[]  @relation("TutorialTranslationAuthor")
  subscriptions         Subscription[]
  paymentCustomers      PaymentCustomer[]
  authSessions          AuthSession[]
  passwordResetTokens   PasswordResetToken[]
  aiKeyCredential       UserAiKeyCredential?
  aiUsageEvents         AiUsageEvent[]

  @@map("users")
}

model UserAiKeyCredential {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  provider        String   @default("openai")
  encryptedSecret String   @map("encrypted_secret")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_ai_key_credentials")
}

model AiUsageEvent {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  action         String
  estimatedUnits Int      @default(0) @map("estimated_units")
  success        Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
  @@map("ai_usage_events")
}

model AuthSession {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  refreshTokenHash String            @map("refresh_token_hash")
  status           AuthSessionStatus @default(ACTIVE)
  userAgent        String?           @map("user_agent")
  ipAddress        String?           @map("ip_address")
  expiresAt        DateTime          @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime?         @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("auth_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("password_reset_tokens")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  userRoles       UserRole[]
  companyMembers  CompanyMember[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId])
  @@index([userId, companyId])
  @@map("user_roles")
}

model Company {
  id                 String                    @id @default(uuid()) @db.Uuid
  name               String
  slug               String                    @unique
  contactName        String?                   @map("contact_name")
  contactDesignation String?                   @map("contact_designation")
  contactEmail       String?                   @map("contact_email")
  contactPhone       String?                   @map("contact_phone")
  addressLine1       String?                   @map("address_line_1")
  businessLicenseNo  String?                   @map("business_license_no")
  companyType        CompanyType               @default(OTHER) @map("company_type")
  orgSize            OrgSize                   @default(SMALL) @map("org_size")
  website            String?
  description        String?
  city               String?
  province           String?
  country            String?
  verificationStatus CompanyVerificationStatus @default(UNVERIFIED) @map("verification_status")
  verifiedAt         DateTime?                 @map("verified_at") @db.Timestamptz(6)
  createdAt          DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?                 @map("deleted_at") @db.Timestamptz(6)

  members               CompanyMember[]
  verificationDocuments CompanyVerificationDocument[]
  jobs                  Job[]
  userRoles             UserRole[]
  mediaAssets           MediaAsset[]
  conversations         Conversation[]
  subscriptions         Subscription[]
  paymentCustomers      PaymentCustomer[]

  @@map("companies")
}

model CompanyMember {
  id          String              @id @default(uuid()) @db.Uuid
  companyId   String              @map("company_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  roleId      String?             @map("role_id") @db.Uuid
  title       String?
  status      CompanyMemberStatus @default(ACTIVE)
  invitedById String?             @map("invited_by_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_members")
}

model CompanyVerificationDocument {
  id           String                     @id @default(uuid()) @db.Uuid
  companyId    String                     @map("company_id") @db.Uuid
  mediaAssetId String                     @map("media_asset_id") @db.Uuid
  docType      CompanyVerificationDocType @map("doc_type")
  status       VerificationStatus         @default(PENDING)
  notes        String?
  createdAt    DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation("CompanyVerificationMediaAsset", fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@map("company_verification_documents")
}

model Candidate {
  id                     String          @id @default(uuid()) @db.Uuid
  userId                 String?         @unique @map("user_id") @db.Uuid
  status                 CandidateStatus @default(UNCLAIMED)
  source                 String?
  profileCompletionScore Int             @default(0) @map("profile_completion_score")
  metadata               Json?
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime?       @map("deleted_at") @db.Timestamptz(6)

  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  profile             CandidateProfile?
  claimTokens         CandidateClaimToken[]
  applications        Application[]
  applicationArchives ApplicationArchive[]
  conversations       Conversation[]

  @@index([profileCompletionScore])
  @@map("candidates")
}

model CandidateClaimToken {
  id              String    @id @default(uuid()) @db.Uuid
  candidateId     String    @map("candidate_id") @db.Uuid
  token           String    @unique
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  claimedByUserId String?   @map("claimed_by_user_id") @db.Uuid
  claimedAt       DateTime? @map("claimed_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, expiresAt])
  @@map("candidate_claim_tokens")
}

model CandidateProfile {
  id                     String                  @id @default(uuid()) @db.Uuid
  candidateId            String                  @unique @map("candidate_id") @db.Uuid
  profileCompletionScore Int                     @default(0) @map("profile_completion_score")
  languageCode           String                  @default("en") @map("language_code")
  fullName               String                  @map("full_name")
  dob                    DateTime?               @db.Date
  fatherName             String?                 @map("father_name")
  motherName             String?                 @map("mother_name")
  nationality            String?
  currentCountry         String?                 @map("current_country")
  currentCity            String?                 @map("current_city")
  phone                  String?
  email                  String?
  gender                 String?
  maritalStatus          String?                 @map("marital_status")
  chinaEducation         Boolean                 @default(false) @map("china_education")
  everBeenToChina        Boolean                 @default(false) @map("ever_been_to_china")
  everRejectedChina      Boolean                 @default(false) @map("ever_rejected_china")
  hskLevel               Int?                    @map("hsk_level")
  englishProficiencyType EnglishProficiencyType? @map("english_proficiency_type")
  englishScoreOverall    Decimal?                @map("english_score_overall") @db.Decimal(5, 2)
  englishScoreReading    Decimal?                @map("english_score_reading") @db.Decimal(5, 2)
  englishScoreWriting    Decimal?                @map("english_score_writing") @db.Decimal(5, 2)
  englishScoreSpeaking   Decimal?                @map("english_score_speaking") @db.Decimal(5, 2)
  englishScoreListening  Decimal?                @map("english_score_listening") @db.Decimal(5, 2)
  englishScoreRaw        Json?                   @map("english_score_raw")
  desiredJobTitles       String[]                @default([]) @map("desired_job_titles")
  desiredCities          String[]                @default([]) @map("desired_cities")
  salaryExpectation      Int?                    @map("salary_expectation")
  salaryCurrency         String?                 @default("CNY") @map("salary_currency")
  visaStatus             String?                 @map("visa_status")
  workPermitStatus       String?                 @map("work_permit_status")
  summary                String?
  extensibleData         Json?                   @map("extensible_data")
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  candidate      Candidate                @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  education      CandidateEducation[]
  experiences    CandidateExperience[]
  skills         CandidateSkill[]
  languages      CandidateLanguage[]
  certifications CandidateCertification[]
  documents      CandidateDocument[]
  passports      CandidatePassport[]
  testScores     CandidateTestScore[]

  @@map("candidate_profiles")
}

model CandidateEducation {
  id                 String    @id @default(uuid()) @db.Uuid
  candidateProfileId String    @map("candidate_profile_id") @db.Uuid
  institution        String
  degree             String?
  degreeType         String?   @map("degree_type")
  fieldOfStudy       String?   @map("field_of_study")
  startDate          DateTime? @map("start_date") @db.Date
  endDate            DateTime? @map("end_date") @db.Date
  isOngoing          Boolean   @default(false) @map("is_ongoing")
  passingYear        Int?      @map("passing_year")
  cgpa               String?
  country            String?
  grade              String?
  description        String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_educations")
}

model CandidateExperience {
  id                 String          @id @default(uuid()) @db.Uuid
  candidateProfileId String          @map("candidate_profile_id") @db.Uuid
  companyName        String          @map("company_name")
  jobTitle           String          @map("job_title")
  employmentType     EmploymentType? @map("employment_type")
  startDate          DateTime?       @map("start_date") @db.Date
  endDate            DateTime?       @map("end_date") @db.Date
  isCurrent          Boolean         @default(false) @map("is_current")
  locationCity       String?         @map("location_city")
  locationCountry    String?         @map("location_country")
  description        String?
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_experiences")
}

model CandidateSkill {
  id                 String   @id @default(uuid()) @db.Uuid
  candidateProfileId String   @map("candidate_profile_id") @db.Uuid
  name               String
  level              String?
  yearsOfExperience  Int?     @map("years_of_experience")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_skills")
}

model CandidateLanguage {
  id                 String   @id @default(uuid()) @db.Uuid
  candidateProfileId String   @map("candidate_profile_id") @db.Uuid
  language           String
  proficiency        String?
  certification      String?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_languages")
}

model CandidateCertification {
  id                 String    @id @default(uuid()) @db.Uuid
  candidateProfileId String    @map("candidate_profile_id") @db.Uuid
  name               String
  issuingOrg         String?   @map("issuing_org")
  issuedAt           DateTime? @map("issued_at") @db.Date
  expiresAt          DateTime? @map("expires_at") @db.Date
  credentialId       String?   @map("credential_id")
  credentialUrl      String?   @map("credential_url")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_certifications")
}

model CandidateDocument {
  id                 String    @id @default(uuid()) @db.Uuid
  candidateProfileId String    @map("candidate_profile_id") @db.Uuid
  mediaAssetId       String?   @map("media_asset_id") @db.Uuid
  documentType       String    @map("document_type")
  title              String?
  languageCode       String?   @map("language_code")
  issuedAt           DateTime? @map("issued_at") @db.Date
  expiresAt          DateTime? @map("expires_at") @db.Date
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  mediaAsset       MediaAsset?      @relation("CandidateDocumentAsset", fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([candidateProfileId])
  @@map("candidate_documents")
}

model CandidatePassport {
  id                 String    @id @default(uuid()) @db.Uuid
  candidateProfileId String    @map("candidate_profile_id") @db.Uuid
  passportNumber     String?   @map("passport_number")
  countryCode        String?   @map("country_code")
  issuedAt           DateTime? @map("issued_at") @db.Date
  expiresAt          DateTime? @map("expires_at") @db.Date
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_passports")
}

model CandidateTestScore {
  id                 String    @id @default(uuid()) @db.Uuid
  candidateProfileId String    @map("candidate_profile_id") @db.Uuid
  testType           String    @map("test_type")
  score              Decimal?  @db.Decimal(8, 2)
  maxScore           Decimal?  @map("max_score") @db.Decimal(8, 2)
  details            Json?
  takenAt            DateTime? @map("taken_at") @db.Date
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_test_scores")
}

model Industry {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  categories JobCategory[]

  @@map("industries")
}

model JobFunction {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  categories JobCategory[]

  @@map("job_functions")
}

model JobCategory {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique
  isActive      Boolean  @default(true) @map("is_active")
  industryId    String   @map("industry_id") @db.Uuid
  jobFunctionId String   @map("job_function_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  industry    Industry    @relation(fields: [industryId], references: [id], onDelete: Cascade)
  jobFunction JobFunction @relation(fields: [jobFunctionId], references: [id], onDelete: Cascade)
  jobs        Job[]

  @@index([industryId, jobFunctionId])
  @@map("job_categories")
}

model TaxonomyTranslation {
  id          String             @id @default(uuid()) @db.Uuid
  entityType  TaxonomyEntityType @map("entity_type")
  entityId    String             @map("entity_id") @db.Uuid
  locale      LocaleCode
  name        String
  description String?
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([entityType, entityId, locale])
  @@index([entityType, locale])
  @@map("taxonomy_translations")
}

model JobTag {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  label     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  jobTags JobTags[]

  @@map("job_tags_catalog")
}

model JobTags {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  job Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
